# Copy to .env and fill in. Keys never go in the Chrome extension.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional (default 8787 — must match lib/api-config.js DEFAULT_SERVER_BASE, or set chrome.storage.local hephaestusServerUrl)
# PORT=8787
# If npm start fails with EADDRINUSE, stop the old process (lsof -nP -iTCP:8787) or change PORT here + extension storage URL.

# Optional: if set, every request must include header x-hephaestus-secret: <same value>
# HEPHAESTUS_PROXY_SECRET=

# Optional: model id for GET /diagnostics Anthropic probe (default claude-haiku-4-5)
# ANTHROPIC_DIAGNOSTIC_MODEL=

# GET /diagnostics (same auth as other routes) runs a tiny Anthropic message + Gemini list-models
# call using these keys — verify with: npm run test-diagnostics (from repo root)

# Anyone who can reach this port can use your API keys. Use only on localhost / trusted networks.
