# Copy to .env and fill in. Keys never go in the Chrome extension.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional (default 8787 — must match Hephaestus extension default in lib/api-config.js, or use side panel Save URL)
# PORT=8787
# If npm start fails with EADDRINUSE, stop the old process (lsof -nP -iTCP:8787) or change PORT here + extension URL.

# Optional: if set, every request must include header x-hephaestus-secret: <same value>
# HEPHAESTUS_PROXY_SECRET=

# Anyone who can reach this port can use your API keys. Use only on localhost / trusted networks.
