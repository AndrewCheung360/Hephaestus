{
  "manifest_version": 3,
  "name": "Hephaestus: Hands-Free Learning Forge",
  "version": "0.1.0",
  "description": "A Claude-powered AI Learning Forge for hands-free study. Head tracking + double-mouth-open opens an Orbital Command Menu at your gaze.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/Readability.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "gaze/gaze-core.js",
        "gaze/head-cal.js",
        "gaze/mouth-cal.js",
        "gaze/gaze-dwell.js",
        "gaze/gaze-overlay.js",
        "gaze/orbital-detector.js",
        "orbital/orbital-menu.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Hephaestus",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/Readability.js",
        "orbital/orbital-menu.css",
        "gaze/gaze-overlay.css",
        "gaze/human/human.esm.js",
        "gaze/human/models/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
